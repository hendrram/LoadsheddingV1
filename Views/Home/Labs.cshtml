@model List<Labs>

<div class="jumbotron" style="background-color: #f0f8ff; border-radius: 20px; padding: 20px;">
    <h2 class="display-4">Enable/Disable Labs</h2>
    <hr class="my-4">
    <form asp-action="UpdateLab">
        <div class="row">
            <div class="col-md-4">
                @for (int i = 0; i < Model.Count && i < 8; i++)
                {
                    <div style="padding-bottom: 10px;">
                        <!-- Added padding-bottom here -->
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="labs[@i].OnOff" id="labCheckbox@(i)" value="true" @(Model[i].OnOff ? "checked" : "") />
                            <label class="form-check-label" for="labCheckbox@(i)">
                                @Model[i].LabName
                            </label>
                        </div>
                        <input type="hidden" name="labs[@i].OnOff" value="false" />
                        <input type="hidden" name="labs[@i].LabName" value="@Model[i].LabName" />
                    </div>
                }
            </div>
            <div class="col-md-4">
                @for (int i = 8; i < Model.Count && i < 16; i++)
                {
                    <div style="padding-bottom: 10px;">
                        <!-- Added padding-bottom here -->
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="labs[@i].OnOff" id="labCheckbox@(i)" value="true" @(Model[i].OnOff ? "checked" : "") />
                            <label class="form-check-label" for="labCheckbox@(i)">
                                @Model[i].LabName
                            </label>
                        </div>
                        <input type="hidden" name="labs[@i].OnOff" value="false" />
                        <input type="hidden" name="labs[@i].LabName" value="@Model[i].LabName" />
                    </div>
                }
            </div>
            <div class="col-md-4">
                @for (int i = 16; i < Model.Count && i < 24; i++)
                {
                    <div style="padding-bottom: 10px;">
                        <!-- Added padding-bottom here -->
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="labs[@i].OnOff" id="labCheckbox@(i)" value="true" @(Model[i].OnOff ? "checked" : "") />
                            <label class="form-check-label" for="labCheckbox@(i)">
                                @Model[i].LabName
                            </label>
                        </div>
                        <input type="hidden" name="labs[@i].OnOff" value="false" />
                        <input type="hidden" name="labs[@i].LabName" value="@Model[i].LabName" />
                    </div>
                }
            </div>
        </div>

        <div class="text-center" style="margin-top: 20px;">
            <input class="btn btn-primary" type="submit" value="Submit">
        </div>
    </form>
</div>
